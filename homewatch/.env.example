# HomeWatch configuration. Copy to .env and fill in real values.
# The real .env is gitignored and must never be committed.

# Flask secret key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-value

# Which config class to load: development | production | testing
HOMEWATCH_CONFIG=development

# Database location (SQLite). Relative paths are resolved from the project root.
DATABASE_URL=sqlite:///homewatch.db

# Network bind address. Defaults to loopback only.
# Set to 0.0.0.0 to expose on the LAN — see the security warnings in README.md first.
HOMEWATCH_BIND=127.0.0.1
HOMEWATCH_PORT=8000

# Scanner (used from Slice 3). Leave blank to auto-detect the primary interface subnet.
HOMEWATCH_SUBNET=

# Scanner discovery backend: scapy | mock
# 'mock' returns synthetic devices for dev/CI where raw sockets are unavailable.
HOMEWATCH_SCAN_BACKEND=mock

# Optional: ICMP-ping a stale device's last IP before marking it offline.
HOMEWATCH_ICMP_CONFIRM=false
